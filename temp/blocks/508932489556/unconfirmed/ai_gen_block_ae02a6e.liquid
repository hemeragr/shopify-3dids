{% doc %}
  @prompt
    Carrusel de productos
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-carousel-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-product-carousel__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 32px;
  }

  .ai-product-carousel__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-product-carousel__container-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-product-carousel__track-wrapper-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-product-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-product-carousel__item-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.products_per_row_desktop | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.products_per_row_desktop }});
    min-width: 0;
  }

  .ai-product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-product-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-card__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-card__info-{{ ai_gen_id }} {
    padding: 16px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-product-card__title-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.card_text_color }};
    margin: 0 0 8px 0;
    font-weight: 500;
    line-height: 1.3;
  }

  .ai-product-card__title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-product-card__title-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-product-card__price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.card_text_color }};
    margin-top: auto;
  }

  .ai-product-carousel__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
  }

  .ai-product-carousel__button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-product-carousel__button-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_color }};
  }

  .ai-product-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-product-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-product-carousel__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-product-carousel__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-product-carousel__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  @media screen and (max-width: 749px) {
    .ai-product-carousel__item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.products_per_row_mobile | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.products_per_row_mobile }});
    }

    .ai-product-carousel__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }
  }
{% endstyle %}

<product-carousel-{{ ai_gen_id }} class="ai-product-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <div class="ai-product-carousel__header-{{ ai_gen_id }}">
      <h2 class="ai-product-carousel__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if block.settings.product_list != blank %}
    <div class="ai-product-carousel__container-{{ ai_gen_id }}">
      <div class="ai-product-carousel__track-wrapper-{{ ai_gen_id }}">
        <div class="ai-product-carousel__track-{{ ai_gen_id }}" data-track>
          {% for product in block.settings.product_list %}
            <div class="ai-product-carousel__item-{{ ai_gen_id }}">
              <div class="ai-product-card-{{ ai_gen_id }}">
                <div class="ai-product-card__image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-product-card__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {% else %}
                    <div class="ai-product-card__placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-product-card__info-{{ ai_gen_id }}">
                  <h3 class="ai-product-card__title-{{ ai_gen_id }}">
                    <a href="{{ product.url }}" class="ai-product-card__title-link-{{ ai_gen_id }}">
                      {{ product.title }}
                    </a>
                  </h3>
                  <div class="ai-product-card__price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      {% if block.settings.show_navigation %}
        <div class="ai-product-carousel__nav-{{ ai_gen_id }}">
          <button
            class="ai-product-carousel__button-{{ ai_gen_id }}"
            data-prev
            aria-label="Anterior"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="12 4 6 10 12 16"></polyline>
            </svg>
          </button>

          {% if block.settings.show_dots %}
            <div class="ai-product-carousel__dots-{{ ai_gen_id }}" data-dots></div>
          {% endif %}

          <button
            class="ai-product-carousel__button-{{ ai_gen_id }}"
            data-next
            aria-label="Siguiente"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="8 4 14 10 8 16"></polyline>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-product-carousel__empty-state-{{ ai_gen_id }}">
      <p>Selecciona productos para mostrar en el carrusel</p>
    </div>
  {% endif %}
</product-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.itemsPerPage = {{ block.settings.products_per_row_desktop }};
        this.itemsPerPageMobile = {{ block.settings.products_per_row_mobile }};
        this.autoplay = {{ block.settings.autoplay }};
        this.autoplaySpeed = {{ block.settings.autoplay_speed | times: 1000 }};
        this.autoplayTimer = null;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');

        if (!this.track) return;

        this.items = Array.from(this.track.children);
        this.totalItems = this.items.length;

        this.updateItemsPerPage();
        this.createDots();
        this.updateCarousel();
        this.setupEventListeners();

        if (this.autoplay) {
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.stopAutoplay();
            this.prev();
            if (this.autoplay) {
              this.startAutoplay();
            }
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.stopAutoplay();
            this.next();
            if (this.autoplay) {
              this.startAutoplay();
            }
          });
        }

        window.addEventListener('resize', () => {
          this.updateItemsPerPage();
          this.updateCarousel();
        });
      }

      updateItemsPerPage() {
        this.itemsPerPage = window.innerWidth <= 749 
          ? this.itemsPerPageMobile 
          : {{ block.settings.products_per_row_desktop }};
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.dotsContainer.innerHTML = '';
        this.totalPages = Math.ceil(this.totalItems / this.itemsPerPage);

        for (let i = 0; i < this.totalPages; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-product-carousel__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Ir a página ${i + 1}`);
          dot.addEventListener('click', () => {
            this.stopAutoplay();
            this.goToPage(i);
            if (this.autoplay) {
              this.startAutoplay();
            }
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      updateCarousel() {
        this.totalPages = Math.ceil(this.totalItems / this.itemsPerPage);
        
        if (this.currentIndex >= this.totalPages) {
          this.currentIndex = Math.max(0, this.totalPages - 1);
        }

        const offset = this.currentIndex * -100;
        this.track.style.transform = `translateX(${offset}%)`;

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }

        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= this.totalPages - 1;
        }

        if (this.dotsContainer) {
          const dots = this.dotsContainer.querySelectorAll('.ai-product-carousel__dot-{{ ai_gen_id }}');
          dots.forEach((dot, index) => {
            dot.classList.toggle('active', index === this.currentIndex);
          });
        }
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      next() {
        if (this.currentIndex < this.totalPages - 1) {
          this.currentIndex++;
          this.updateCarousel();
        } else if (this.autoplay) {
          this.currentIndex = 0;
          this.updateCarousel();
        }
      }

      goToPage(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayTimer = setInterval(() => {
          this.next();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;
        }
      }
    }

    customElements.define('product-carousel-{{ ai_gen_id }}', ProductCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Carrusel de productos",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Título",
      "default": "Productos destacados"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alineación del título",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño del título",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Productos"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Productos",
      "limit": 12
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "label": "Productos por fila (escritorio)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "Productos por fila (móvil)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacio entre productos",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Navegación"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Mostrar navegación",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Mostrar puntos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Reproducción automática",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Velocidad de reproducción",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "header",
      "content": "Estilo de tarjeta"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Color de texto",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Color de borde",
      "default": "#e6e6e6"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Radio de borde",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Botones de navegación"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Color de icono",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Color de borde",
      "default": "#e6e6e6"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Fondo al pasar",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Color de icono al pasar",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Color de puntos",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Relleno de sección",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Carrusel de productos"
    }
  ]
}
{% endschema %}
