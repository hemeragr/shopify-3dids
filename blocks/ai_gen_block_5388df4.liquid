{% doc %}
  @prompt
    Crea una sección de carrusel de reseñas de usuarios para Shopify, con 4 tarjetas visibles en desktop, estilo limpio y premium, título centrado, estrellas arriba, tarjetas blancas con avatar circular, nombre, verified purchase, fecha, estrellas, título de reseña, texto y producto reseñado abajo. Todo editable desde bloques en el editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-carousel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-reviews-carousel__container-{{ ai_gen_id }} {
    max-width: 1680px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .ai-reviews-carousel__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.title_spacing }}px;
  }

  .ai-reviews-carousel__title-{{ ai_gen_id }} {
    font-size: clamp(34px, 4vw, {{ block.settings.title_size }}px);
    color: #2f3f9d;
    font-weight: 500;
    line-height: 1.1;
    margin: 0 0 16px 0;
  }

  .ai-reviews-carousel__summary-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .ai-reviews-carousel__summary-stars-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 4px;
  }

  .ai-reviews-carousel__summary-star-{{ ai_gen_id }} {
    width: 28px;
    height: 28px;
    fill: #f4b400;
  }

  .ai-reviews-carousel__summary-text-{{ ai_gen_id }} {
    margin: 0;
    font-size: 16px;
    color: #2f3f9d;
  }

  .ai-reviews-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin: 0 auto;
  }

  .ai-reviews-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.45s ease;
    will-change: transform;
  }

  .ai-reviews-carousel__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 3)) / 4);
    background: #f7f7f7;
    border-radius: 16px;
    padding: 15px 15px 10px;
    box-shadow: none;
    display: flex;
    flex-direction: column;
    gap: 18px;
    min-height: 300px;
  }

  .ai-reviews-carousel__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    justify-content: center;
    margin-bottom: 4px;
  }

  .ai-reviews-carousel__star-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
    fill: #f4b400;
  }

  .ai-reviews-carousel__author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .ai-reviews-carousel__avatar-{{ ai_gen_id }},
  .ai-reviews-carousel__avatar-placeholder-{{ ai_gen_id }} {
    width: 62px;
    height: 62px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .ai-reviews-carousel__avatar-placeholder-{{ ai_gen_id }} {
    background-color: #dddddd;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-reviews-carousel__avatar-placeholder-{{ ai_gen_id }} svg {
    width: 55%;
    height: 55%;
    fill: #9d9d9d;
  }

  .ai-reviews-carousel__author-info-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-reviews-carousel__author-name-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 700;
    color: #000000;
    margin: 0 0 6px 0;
    line-height: 1.15;
  }

  .ai-reviews-carousel__verified-{{ ai_gen_id }} {
    font-size: 12px;
    color: #4caf50;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-reviews-carousel__verified-icon-{{ ai_gen_id }} {
    width: 12px;
    height: 14px;
    fill: #4caf50;
  }

  .ai-reviews-carousel__date-{{ ai_gen_id }} {
    font-size: 12px;
    color: #8a8a8a;
    text-align: left;
    margin-top: -8px;
  }

  .ai-reviews-carousel__review-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 700;
    color: #2f3f9d;
    margin: 0;

    line-height: 1.15;
  }

  .ai-reviews-carousel__review-text-{{ ai_gen_id }} {
    font-size: 12px;
    color: #222222;
    line-height: 1.55;
    flex: 1;
    margin: 0;
  }

  .ai-reviews-carousel__product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 18px;
    margin-top: auto;
    border-top: 1px solid #dddddd;
  }

  .ai-reviews-carousel__product-image-{{ ai_gen_id }},
  .ai-reviews-carousel__product-placeholder-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .ai-reviews-carousel__product-placeholder-{{ ai_gen_id }} {
    background-color: #ececec;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-reviews-carousel__product-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    fill: #b8b8b8;
  }

  .ai-reviews-carousel__product-name-{{ ai_gen_id }} {
    font-size: 8px;
    line-height: 1.45;
    color: #000000;
    margin: 0;
    flex: 1;
    min-width: 0;
    font-weight: 500;
  }

  .ai-reviews-carousel__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 38px;
  }

  .ai-reviews-carousel__nav-button-{{ ai_gen_id }} {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: #f8f8f8;
    border: 1px solid #e1e1e1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .ai-reviews-carousel__nav-button-{{ ai_gen_id }}:hover {
    background-color: #efefef;
  }

  .ai-reviews-carousel__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .ai-reviews-carousel__nav-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    fill: #7d7d7d;
  }

  @media screen and (max-width: 1200px) {
    .ai-reviews-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.card_gap }}px * 2)) / 3);
    }
  }

  @media screen and (max-width: 900px) {
    .ai-reviews-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
    }
  }

  @media screen and (max-width: 600px) {
    .ai-reviews-carousel__container-{{ ai_gen_id }} {
      padding: 0 20px;
    }

    .ai-reviews-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 100%;
      min-height: auto;
    }

    .ai-reviews-carousel__title-{{ ai_gen_id }} {
      font-size: 34px;
    }

    .ai-reviews-carousel__review-title-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-reviews-carousel__review-text-{{ ai_gen_id }} {
      font-size: 15px;
    }
  }
{% endstyle %}

<reviews-carousel-{{ ai_gen_id }} class="ai-reviews-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reviews-carousel__container-{{ ai_gen_id }}">
  {% if block.settings.title != blank %}
    <div class="ai-reviews-carousel__header-{{ ai_gen_id }}">
      <h2 class="ai-reviews-carousel__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>

      <div class="ai-reviews-carousel__summary-{{ ai_gen_id }}">
        <div class="ai-reviews-carousel__summary-stars-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            <svg class="ai-reviews-carousel__summary-star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {% endfor %}
        </div>
        {% if block.settings.summary_text != blank %}
          <p class="ai-reviews-carousel__summary-text-{{ ai_gen_id }}">{{ block.settings.summary_text }}</p>
        {% endif %}
      </div>
    </div>
  {% endif %}

    <div class="ai-reviews-carousel__wrapper-{{ ai_gen_id }}">
      <div class="ai-reviews-carousel__track-{{ ai_gen_id }}" data-track>
        {% for i in (1..8) %}
          {% liquid
            assign rating_key = 'review_' | append: i | append: '_rating'
            assign avatar_key = 'review_' | append: i | append: '_avatar'
            assign name_key = 'review_' | append: i | append: '_name'
            assign verified_key = 'review_' | append: i | append: '_verified'
            assign verified_text_key = 'review_' | append: i | append: '_verified_text'
            assign date_key = 'review_' | append: i | append: '_date'
            assign title_key = 'review_' | append: i | append: '_title'
            assign text_key = 'review_' | append: i | append: '_text'
            assign product_key = 'review_' | append: i | append: '_product'

            assign rating = block.settings[rating_key]
            assign avatar = block.settings[avatar_key]
            assign name = block.settings[name_key]
            assign verified = block.settings[verified_key]
            assign verified_text = block.settings[verified_text_key]
            assign date = block.settings[date_key]
            assign title = block.settings[title_key]
            assign text = block.settings[text_key]
            assign product = block.settings[product_key]
          %}

          {% if name != blank %}
            <div class="ai-reviews-carousel__card-{{ ai_gen_id }}">
              <div class="ai-reviews-carousel__stars-{{ ai_gen_id }}">
                {% for j in (1..5) %}
                  {% if j <= rating %}
                    <svg class="ai-reviews-carousel__star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% else %}
                    <svg class="ai-reviews-carousel__star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="fill: #e0e0e0;">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endif %}
                {% endfor %}
              </div>

              <div class="ai-reviews-carousel__author-{{ ai_gen_id }}">
                {% if avatar %}
                  <img
                    src="{{ avatar | image_url: width: 100 }}"
                    alt="{{ name }}"
                    class="ai-reviews-carousel__avatar-{{ ai_gen_id }}"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                {% else %}
                  <div class="ai-reviews-carousel__avatar-placeholder-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                  </div>
                {% endif %}

                <div class="ai-reviews-carousel__author-info-{{ ai_gen_id }}">
                  <h3 class="ai-reviews-carousel__author-name-{{ ai_gen_id }}">{{ name }}</h3>
                  {% if verified %}
                    <div class="ai-reviews-carousel__verified-{{ ai_gen_id }}">
                      <svg class="ai-reviews-carousel__verified-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                      </svg>
                      <span>{{ verified_text }}</span>
                    </div>
                  {% endif %}
                </div>
              </div>

              {% if date != blank %}
                <div class="ai-reviews-carousel__date-{{ ai_gen_id }}">{{ date }}</div>
              {% endif %}

              {% if title != blank %}
                <h4 class="ai-reviews-carousel__review-title-{{ ai_gen_id }}">{{ title }}</h4>
              {% endif %}

              {% if text != blank %}
                <p class="ai-reviews-carousel__review-text-{{ ai_gen_id }}">{{ text }}</p>
              {% endif %}

              {% if product %}
                <div class="ai-reviews-carousel__product-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 100 }}"
                      alt="{{ product.title }}"
                      class="ai-reviews-carousel__product-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="100"
                      height="100"
                    >
                  {% else %}
                    <div class="ai-reviews-carousel__product-placeholder-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M21 16V8c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM5 8h14v8H5V8z"/>
                      </svg>
                    </div>
                  {% endif %}
                  <p class="ai-reviews-carousel__product-name-{{ ai_gen_id }}">{{ product.title }}</p>
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-reviews-carousel__nav-{{ ai_gen_id }}">
      <button class="ai-reviews-carousel__nav-button-{{ ai_gen_id }}" data-prev aria-label="Anterior">
        <svg class="ai-reviews-carousel__nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
        </svg>
      </button>
      <button class="ai-reviews-carousel__nav-button-{{ ai_gen_id }}" data-next aria-label="Siguiente">
        <svg class="ai-reviews-carousel__nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
        </svg>
      </button>
    </div>
  </div>
</reviews-carousel-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Carrusel de reseñas",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Título"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Lo que dicen nuestros clientes"
    },
    {
      "type": "text",
      "id": "summary_text",
      "label": "Texto debajo de estrellas",
      "default": "4.7 calificación de 70 reseñas"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño del título",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del título",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Espacio debajo del título",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Sección"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f9f9f9"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Tarjetas"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Fondo de tarjeta",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Radio de borde",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Padding interno",
      "min": 15,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Espacio entre tarjetas",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_shadow_x",
      "label": "Sombra X",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_shadow_y",
      "label": "Sombra Y",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "card_shadow_blur",
      "label": "Difuminado de sombra",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "card_shadow_color",
      "label": "Color de sombra",
      "default": "#00000010"
    },
    {
      "type": "header",
      "content": "Estrellas"
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Tamaño",
      "min": 12,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Color",
      "default": "#ffc107"
    },
    {
      "type": "header",
      "content": "Avatar"
    },
    {
      "type": "range",
      "id": "avatar_size",
      "label": "Tamaño",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color",
      "id": "avatar_placeholder_color",
      "label": "Color de fondo placeholder",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "avatar_placeholder_icon_color",
      "label": "Color de icono placeholder",
      "default": "#9e9e9e"
    },
    {
      "type": "header",
      "content": "Autor"
    },
    {
      "type": "range",
      "id": "author_name_size",
      "label": "Tamaño del nombre",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "author_name_color",
      "label": "Color del nombre",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "verified_size",
      "label": "Tamaño texto verificado",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "verified_color",
      "label": "Color verificado",
      "default": "#4caf50"
    },
    {
      "type": "header",
      "content": "Fecha"
    },
    {
      "type": "range",
      "id": "date_size",
      "label": "Tamaño",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "date_color",
      "label": "Color",
      "default": "#757575"
    },
    {
      "type": "header",
      "content": "Reseña"
    },
    {
      "type": "range",
      "id": "review_title_size",
      "label": "Tamaño del título",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "review_title_color",
      "label": "Color del título",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "review_text_size",
      "label": "Tamaño del texto",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "review_text_color",
      "label": "Color del texto",
      "default": "#424242"
    },
    {
      "type": "header",
      "content": "Producto"
    },
    {
      "type": "range",
      "id": "product_image_size",
      "label": "Tamaño de imagen",
      "min": 40,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "product_image_radius",
      "label": "Radio de borde",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "product_name_size",
      "label": "Tamaño del nombre",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "product_name_color",
      "label": "Color del nombre",
      "default": "#000000"
    },
    {
      "type": "color",
