{% assign product = closest.product %}

{% capture children %}
  {% unless product == blank %}
    {% assign nivel_texto = blank %}
    {% assign nivel_clase = blank %}

    {% if product.tags contains 'Iniciacion' or product.tags contains 'Iniciación' %}
      {% assign nivel_texto = 'Iniciación' %}
      {% assign nivel_clase = 'iniciacion' %}
    {% elsif product.tags contains 'Iniciados' %}
      {% assign nivel_texto = 'Iniciados' %}
      {% assign nivel_clase = 'iniciados' %}
    {% elsif product.tags contains 'Experimentados' %}
      {% assign nivel_texto = 'Experimentados' %}
      {% assign nivel_clase = 'experimentados' %}
    {% elsif product.tags contains 'Experto' %}
      {% assign nivel_texto = 'Experto' %}
      {% assign nivel_clase = 'experto' %}
    {% endif %}

    <div class="product-card-top-ui">
      {% if nivel_texto != blank %}
        <div class="product-level-badge product-level-badge--{{ nivel_clase }}">
          <span class="product-level-badge__dot"></span>
          <span>{{ nivel_texto }}</span>
        </div>
      {% endif %}

      <button class="product-card-wishlist" type="button" aria-label="Añadir a favoritos">
        ♡
      </button>
    </div>

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add', product: product, section_id: section.id %}
    {% endif %}
  {% endunless %}
{% endcapture %}

{% render 'card-gallery', children: children %}

{% # Title and price for the zoomed out grid view %}
<div class="product-grid-view-zoom-out--details">
  {% if product == blank %}
    <h3 class="h4">{{ 'content.product_card_placeholder' | t }}</h3>
  {% else %}
    <h3 class="h4">{{ product.title }}</h3>
  {% endif %}
</div>

{% stylesheet %}
  .product-card-top-ui {
    position: absolute;
    top: 5px;
    left: 5px;
    right: 5px;
    z-index: 50;
    display: flex;
    justify-content: space-between;
  }

  .product-level-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 2px 8px;
    border-radius: 999px;
    background: #ffffff;
    border: 1px solid #273488;
    color: #273488;
    font-size: 11px;
  }

  .product-level-badge__dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }

  /* Colores según etiqueta */
  .product-level-badge--iniciacion .product-level-badge__dot {
    background: #67d45a; /* verde */
  }

  .product-level-badge--iniciados .product-level-badge__dot {
    background: #efc533; /* amarillo */
  }

  .product-level-badge--experimentados .product-level-badge__dot {
    background: #f29f3f; /* naranja */
  }

  .product-level-badge--experto .product-level-badge__dot {
    background: #e25b4f; /* rojo */
  }

  .product-card-wishlist {
    width: 14px;
    height: 14px;
    border: none;
    background: transparent;
    color: #273488;
    font-size: 14px;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
  }

  .product-card-wishlist:hover {
    transform: scale(1.08);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_image",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "portrait",
      "label": "t:settings.aspect_ratio",
      "info": "t:info.aspect_ratio_adjusted"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_card_media",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}