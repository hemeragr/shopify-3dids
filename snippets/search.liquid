{%- doc -%}
  Renders the search action as a visible search bar.

  @param {string} [style] - The style of the search action.
  @param {string} [class] - Additional classes for the search action.
  @param {string} [display_style] - The display style ('icon' or 'text').
{%- enddoc -%}

{% unless style == 'none' %}
  <div class="search-action{% if class != blank %} {{ class | strip }}{% endif %}">
    <form action="{{ routes.search_url }}" method="get" role="search" class="header-search-form">
      <input
        type="search"
        name="q"
        class="header-search-input"
        placeholder="Buscar"
        value="{{ search.terms | escape }}"
        aria-label="{{ 'content.search_input_label' | t }}"
      >
      <button
        type="submit"
        class="header-search-button"
        aria-label="{{ 'content.search' | t }}"
      >
        <span class="svg-wrapper">
          {{ 'icon-search.svg' | inline_asset_content }}
        </span>
      </button>
    </form>
  </div>
{% endunless %}

{% stylesheet %}
  .search-action {
    --search-border-radius: 999px;
    --search-border-width: 1px;
    display: flex;
    width: 100%;
  }

  .header-search-form {
    display: flex;
    align-items: center;
    width: 100%;
    min-width: 220px;
    max-width: 320px;
    border: var(--search-border-width) solid currentColor;
    border-radius: var(--search-border-radius);
    overflow: hidden;
    background: transparent;
  }

  .header-search-input {
    width: 100%;
    border: 0;
    outline: none;
    background: transparent;
    color: inherit;
    padding: 0.7rem 1rem;
    font: inherit;
    min-width: 0;
  }

  .header-search-input::placeholder {
    color: inherit;
    opacity: 0.7;
  }

  .header-search-button {
    border: 0;
    background: transparent;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.9rem;
    cursor: pointer;
    flex-shrink: 0;
  }

  .header-search-button .svg-wrapper {
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header-search-button svg {
    width: 18px;
    height: 18px;
  }

  @media screen and (max-width: 749px) {
    .search-action--hidden-on-drawer {
      display: none;
    }

    .header-search-form {
      min-width: 160px;
      max-width: 100%;
    }

    .header-search-input {
      padding: 0.6rem 0.8rem;
    }
  }

  @media screen and (min-width: 750px) {
    [data-menu-style='drawer'] .search-action--hidden-on-drawer {
      display: none;
    }

    [data-menu-style='menu'] .search-action--hidden-on-menu {
      display: none;
    }

    [data-menu-style='menu'] .header__column--left .search-action {
      margin-inline: 0;
    }

    .header__column--right .search-action {
      margin-inline: 0;
      justify-content: flex-end;
    }
  }
{% endstylesheet %}