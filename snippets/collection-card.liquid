{%- doc -%}
  This snippet is used to render a collection card.
{%- enddoc -%}

{% style %}
  {% if request.visual_preview_mode %}
    .collection-card {
      min-width: 250px;
    }
  {% endif %}
{% endstyle %}

{% liquid
  assign onboarding = false
  assign block_settings = block.settings

  if collection == blank
    assign onboarding = true
  endif
%}

<div
  class="
    collection-card
    collection-card--custom
    border-style
    {% if block_settings.placement == 'on_image' %}collection-card--image-bg{% endif %}
    {% if section.settings.layout_type == 'bento' %}collection-card--image-height-fixed{% endif %}
    {% if section.settings.layout_type == 'editorial' %}collection-card--flexible-aspect-ratio{% endif %}
    {% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}
  "
  data-block-id="{{ block.id }}"
  {% if onboarding %}
    data-placeholder="true"
  {% endif %}
  style="
    {% render 'border-override', settings: block_settings %}
    --horizontal-alignment: {{ block_settings.horizontal_alignment }};
    --vertical-alignment: {{ block_settings.vertical_alignment }};
    --background-overlay-color: {{ block_settings.overlay_color }};
    --gap: {{ block_settings.collection_card_gap }}px;
  "
  {{- block.shopify_attributes -}}
>
  <a
    class="collection-card__link"
    {% unless onboarding %}
      href="{{ collection.url }}"
    {% endunless %}
  >
    <span class="visually-hidden">{{ collection.title }}</span>
  </a>

  <div class="collection-card__inner">
    <div class="collection-card__title-top">
      {% if onboarding %}
        MAQUETA DE COLECCIÓN
      {% else %}
        {{ collection.title }}
      {% endif %}
    </div>

    <div class="collection-card__image-wrap">
      {{ card_image }}
    </div>

    <div class="collection-card__footer">
      <span class="collection-card__button-look">
        DESCUBRIR
      </span>
    </div>

    <div class="collection-card__content layout-panel-flex--column visually-hidden">
      {{ children }}
    </div>
  </div>
</div>

{% stylesheet %}
  .collection-card {
    --fixed-card-height: var(--height-small);
    flex: 1 1 var(--card-width-small);
  }

  .collection-card > svg {
    height: 100%;
    width: 100%;
    aspect-ratio: var(--ratio);
  }

  .collection-card__inner {
    gap: var(--gap);
  }

  .collection-card__content {
    max-width: 100%;
    --flex-wrap: wrap;
  }

  .collection-card.collection-card--image-bg {
    aspect-ratio: var(--ratio);
  }

  .collection-card.collection-card--image-bg .collection-card__content {
    padding: var(--padding-lg);
  }

  .collection-card--image-height-fixed {
    height: 100%;
  }

  .collection-card--image-height-fixed .collection-card__image {
    height: var(--fixed-card-height);
    width: 100%;
  }

  .collection-card--image-height-fixed.collection-card--image-bg {
    height: var(--fixed-card-height);
    aspect-ratio: unset;
  }

  .collection-card__image .image-block__image {
    object-fit: contain;
    width: 100%;
    height: 100%;
    max-width: 100%;
  }

  .collection-card--image-bg .collection-card__image {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .collection-card__image svg {
    height: 100%;
    width: 100%;
  }

  .resource-list:not(.hidden--desktop) .collection-card--flexible-aspect-ratio {
    &.collection-card.collection-card--image-bg,
    &.collection-card .placeholder-svg {
      aspect-ratio: 99;
    }
  }
/* =========================
   ESTILO CUSTOM COMO REFERENCIA
   ========================= */

.collection-card--custom {
  position: relative;
  height: 100%;
}

.collection-card--custom .collection-card__link {
  position: absolute;
  inset: 0;
  z-index: 4;
}
.collection-card--custom .collection-card__inner {
  position: relative;
  z-index: 1;
  background: #eef0f8;
  border-radius: 28px;
  height: 100%;
  min-height: 440px; /* antes 620 */
  padding: 22px 18px 22px;
  display: grid;
  grid-template-rows: 56px 1fr auto; /* más compacto */
  box-sizing: border-box;
  overflow: hidden;
}

.collection-card--custom .collection-card__title-top {
  color: #273488;
  text-align: center;
  text-transform: uppercase;
  font-size: 20px; /* antes 28 */
  line-height: 1.05;
  font-weight: 700;
  margin: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  min-height: 56px;
  max-height: 56px;
  overflow: hidden;
  text-wrap: balance;
}

.collection-card--custom .collection-card__image-wrap {
  position: relative;
  min-height: 0;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 8px 0 10px;
}

.collection-card--custom .collection-card__image svg,
.collection-card--custom .collection-card__image img,
.collection-card--custom .image-block__image,
.collection-card--custom picture img {
  position: relative !important;
  display: block;
  width: auto !important;
  height: auto !important;
  max-width: 100%;
  max-height: 170px !important; /* antes 260 */
  object-fit: contain !important;
  margin: 0 auto;
}

.collection-card--custom .collection-card__footer {
  position: relative;
  z-index: 3;
  margin-top: 4px;
  display: flex;
  justify-content: center;
  align-items: end;
}

.collection-card--custom .collection-card__button-look {
  min-width: 72%;
  height: 40px; /* antes 48 */
  border-radius: 999px;
  background: #ffffff;
  color: #273488;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-transform: uppercase;
  font-size: 14px;
  font-weight: 500;
  padding: 0 20px;
  box-sizing: border-box;
}

.collection-card--custom:hover .collection-card__button-look {
  background: #273488;
  color: #ffffff;
  transition: all 0.25s ease;
}

/* ocultamos el contenido nativo */
.collection-card--custom .collection-card__content {
  display: none !important;
}

/* evita reglas heredadas problemáticas */
.collection-card--custom.collection-card--image-bg .collection-card__image,
.collection-card--custom.collection-card--image-bg .collection-card__content {
  position: relative !important;
  height: auto !important;
  width: auto !important;
  padding: 0 !important;
}

/* Responsive */
@media screen and (max-width: 1200px) {
  .collection-card--custom .collection-card__inner {
    min-height: 560px;
    grid-template-rows: 78px 1fr auto;
  }

  .collection-card--custom .collection-card__title-top {
    font-size: 24px;
    min-height: 78px;
    max-height: 78px;
  }

  .collection-card--custom .collection-card__image svg,
  .collection-card--custom .collection-card__image img,
  .collection-card--custom .image-block__image,
  .collection-card--custom picture img {
    max-height: 220px !important;
  }
}

@media screen and (max-width: 749px) {
  .collection-card--custom .collection-card__inner {
    min-height: 470px;
    border-radius: 22px;
    padding: 22px 18px 24px;
    grid-template-rows: 68px 1fr auto;
  }

  .collection-card--custom .collection-card__title-top {
    font-size: 20px;
    min-height: 68px;
    max-height: 68px;
  }

  .collection-card--custom .collection-card__image svg,
  .collection-card--custom .collection-card__image img,
  .collection-card--custom .image-block__image,
  .collection-card--custom picture img {
    max-height: 180px !important;
  }

  .collection-card--custom .collection-card__button-look {
    min-width: 86%;
    height: 44px;
    font-size: 15px;
  }
}
  
{% endstylesheet %}