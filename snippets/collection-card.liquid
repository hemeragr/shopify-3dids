{%- doc -%}
  This snippet is used to render a collection card.
{%- enddoc -%}

{% style %}
  {% if request.visual_preview_mode %}
    .collection-card {
      min-width: 250px;
    }
  {% endif %}
{% endstyle %}

{% liquid
  assign onboarding = false
  assign block_settings = block.settings

  if collection == blank
    assign onboarding = true
  endif
%}

<div
  class="
    collection-card
    collection-card--custom
    {% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}
  "
  data-block-id="{{ block.id }}"
  {% if onboarding %}
    data-placeholder="true"
  {% endif %}
  {{- block.shopify_attributes -}}
>
  <a
    class="collection-card__plain-link"
    {% unless onboarding %}
      href="{{ collection.url }}"
    {% endunless %}
  >
    <div class="collection-card__inner">
      <div class="collection-card__title-top">
        {% if onboarding %}
          MAQUETA DE COLECCIÓN
        {% else %}
          {{ collection.title }}
        {% endif %}
      </div>

      <div class="collection-card__image-wrap">
        {{ card_image }}
      </div>

      <div class="collection-card__footer">
        <span class="collection-card__button-look">
          DESCUBRIR
        </span>
      </div>
    </div>
  </a>

  <div class="collection-card__content visually-hidden">
    {{ children }}
  </div>
</div>

{% stylesheet %}
  .collection-card {
    --fixed-card-height: var(--height-small);
    flex: 1 1 var(--card-width-small);
  }

  .collection-card > svg {
    height: 100%;
    width: 100%;
    aspect-ratio: var(--ratio);
  }

  .collection-card__inner {
    gap: var(--gap);
  }

  .collection-card__content {
    max-width: 100%;
    --flex-wrap: wrap;
  }

  .collection-card.collection-card--image-bg {
    aspect-ratio: var(--ratio);
  }

  .collection-card.collection-card--image-bg .collection-card__content {
    padding: var(--padding-lg);
  }

  .collection-card--image-height-fixed {
    height: 100%;
  }

  .collection-card--image-height-fixed .collection-card__image {
    height: var(--fixed-card-height);
    width: 100%;
  }

  .collection-card--image-height-fixed.collection-card--image-bg {
    height: var(--fixed-card-height);
    aspect-ratio: unset;
  }

  .collection-card__image .image-block__image {
    object-fit: contain;
    width: 100%;
    height: 100%;
    max-width: 100%;
  }

  .collection-card--image-bg .collection-card__image {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .collection-card__image svg {
    height: 100%;
    width: 100%;
  }

  .resource-list:not(.hidden--desktop) .collection-card--flexible-aspect-ratio {
    &.collection-card.collection-card--image-bg,
    &.collection-card .placeholder-svg {
      aspect-ratio: 99;
    }
  }
/* =========================
   ESTILO CUSTOM COMO REFERENCIA
   ========================= */

.collection-card--custom {
  position: relative;
  height: 100%;
}

.collection-card--custom .collection-card__link {
  position: absolute;
  inset: 0;
  z-index: 4;
}
.collection-card--custom .collection-card__inner {
  background: #eef0f8;
  border-radius: 24px;
  padding: 18px 16px 18px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: 320px;
  height: 100%;
  overflow: hidden;
}

.collection-card--custom .collection-card__title-top {
  color: #273488;
  text-align: center;
  text-transform: uppercase;
  font-size: 18px;
  line-height: 1.1;
  font-weight: 700;
  margin: 0 0 12px 0;
  min-height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.collection-card--custom .collection-card__image-wrap {
  width: 100%;
  min-height: 130px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14px;
  overflow: hidden;
}

.collection-card--custom .collection-card__image img,
.collection-card--custom .image-block__image,
.collection-card--custom picture img,
.collection-card--custom .collection-card__image svg {
  display: block;
  max-width: 100%;
  max-height: 175px;
  width: auto;
  height: auto;
  object-fit: contain;
  margin: 0 auto;
}

.collection-card--custom .collection-card__footer {
  margin-top: auto;
  width: 100%;
  display: flex;
  justify-content: center;
}

.collection-card--custom .collection-card__button-look {
  min-width: 72%;
  height: 38px;
  border-radius: 999px;
  background: #ffffff;
  color: #273488;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-transform: uppercase;
  font-size: 13px;
  font-weight: 500;
  padding: 0 18px;
  box-sizing: border-box;
}
.collection-card--custom:hover .collection-card__button-look {
  background: #273488;
  color: #ffffff;
  transition: all 0.25s ease;
}

/* ocultamos el contenido nativo */
.collection-card--custom .collection-card__content {
  display: none !important;
}

/* evita reglas heredadas problemáticas */
.collection-card--custom.collection-card--image-bg .collection-card__image,
.collection-card--custom.collection-card--image-bg .collection-card__content {
  position: relative !important;
  height: auto !important;
  width: auto !important;
  padding: 0 !important;
}

/* Responsive */
@media screen and (max-width: 1200px) {
  .collection-card--custom .collection-card__inner {
    min-height: 560px;
    grid-template-rows: 78px 1fr auto;
  }

  .collection-card--custom .collection-card__title-top {
    font-size: 24px;
    min-height: 78px;
    max-height: 78px;
  }

  .collection-card--custom .collection-card__image svg,
  .collection-card--custom .collection-card__image img,
  .collection-card--custom .image-block__image,
  .collection-card--custom picture img {
    max-height: 220px !important;
  }
}

@media screen and (max-width: 749px) {
  .collection-card--custom .collection-card__inner {
    min-height: 470px;
    border-radius: 22px;
    padding: 22px 18px 24px;
    grid-template-rows: 68px 1fr auto;
  }

  .collection-card--custom .collection-card__title-top {
    font-size: 20px;
    min-height: 68px;
    max-height: 68px;
  }

  .collection-card--custom .collection-card__image svg,
  .collection-card--custom .collection-card__image img,
  .collection-card--custom .image-block__image,
  .collection-card--custom picture img {
    max-height: 180px !important;
  }

  .collection-card--custom .collection-card__button-look {
    min-width: 86%;
    height: 44px;
    font-size: 15px;
  }
}
  
{% endstylesheet %}