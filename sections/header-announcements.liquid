
{% if section.blocks.size > 1 %}
  <script
    src="{{ 'announcement-bar.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<aside
  class="announcement-bar spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}; --border-bottom-width: {{ section.settings.divider_width }}px;"
>
  {% liquid
    assign autoplay = false
    assign show_arrows = false
    if section.blocks.size > 1
      assign autoplay = true
      assign show_arrows = true
    endif
  %}

  <div class="announcement-bar__layout">
    <div class="announcement-bar__side announcement-bar__side--left">
      {% if section.settings.left_text != blank %}
        {% if section.settings.left_link != blank %}
          <a href="{{ section.settings.left_link }}" class="announcement-bar__side-link">
            {% if section.settings.show_location_icon %}
              <span class="announcement-bar__icon" aria-hidden="true">📍</span>
            {% endif %}
            <span>{{ section.settings.left_text }}</span>
          </a>
        {% else %}
          <div class="announcement-bar__side-text">
            {% if section.settings.show_location_icon %}
              <span class="announcement-bar__icon" aria-hidden="true">📍</span>
            {% endif %}
            <span>{{ section.settings.left_text }}</span>
          </div>
        {% endif %}
      {% endif %}
    </div>

    <announcement-bar-component
      class="announcement-bar__slider"
      {% if autoplay == true %}
        autoplay="{{ section.settings.speed }}" aria-live="polite"
      {% endif %}
    >
      {% if show_arrows %}
        {% render 'slideshow-arrows', icon_style: 'chevron' %}
      {% endif %}

      <div class="announcement-bar__slides">
        {% content_for 'blocks' %}
      </div>
    </announcement-bar-component>

    <div class="announcement-bar__side announcement-bar__side--right">
      {% if section.settings.right_link_1_text != blank %}
        <a href="{{ section.settings.right_link_1_url }}" class="announcement-bar__side-link">
          {{ section.settings.right_link_1_text }}
        </a>
      {% endif %}

      {% if section.settings.show_right_separator %}
        <span class="announcement-bar__separator">|</span>
      {% endif %}

      {% if section.settings.right_link_2_text != blank %}
        <a href="{{ section.settings.right_link_2_url }}" class="announcement-bar__side-link">
          {% if section.settings.right_flag != blank %}
            <img
              class="announcement-bar__flag"
              src="{{ section.settings.right_flag | image_url: width: 40 }}"
              alt="{{ section.settings.right_link_2_text | escape }}"
              loading="lazy"
              width="{{ section.settings.right_flag.width }}"
              height="{{ section.settings.right_flag.height }}"
            >
          {% endif %}
          <span>{{ section.settings.right_link_2_text }}</span>
          {% if section.settings.show_language_arrow %}
            <span class="announcement-bar__chevron" aria-hidden="true">+</span>
          {% endif %}
        </a>
      {% endif %}
    </div>
  </div>
</aside>

{% stylesheet %}
  .announcement-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
  }

  .announcement-bar__layout {
    display: grid;
    grid-template-columns: 1fr minmax(0, 680px) 1fr;
    align-items: center;
    gap: 20px;
    width: 100%;
  }

  .announcement-bar__side {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .announcement-bar__side--left {
    justify-content: flex-start;
  }

  .announcement-bar__side--right {
    justify-content: flex-end;
    gap: 12px;
    flex-wrap: wrap;
  }

  .announcement-bar__side-link,
  .announcement-bar__side-text {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.8rem;
    line-height: 1.2;
    white-space: nowrap;
  }

  .announcement-bar__separator {
    opacity: 0.5;
  }

  .announcement-bar__icon {
    display: inline-flex;
    line-height: 1;
  }

  .announcement-bar__flag {
    width: 20px;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .announcement-bar__chevron {
    font-size: 1.1rem;
    line-height: 1;
  }

  .announcement-bar__slider {
    display: flex;
    flex-direction: row;
    align-items: center;
    position: relative;
    min-width: 0;
  }

  .announcement-bar__slides {
    display: grid;
    grid: [stack] auto / [stack] auto;
    width: calc(100% - var(--button-size) * 2);
    max-width: 680px;
    margin-inline: auto;
  }

  .announcement-bar__slides > * {
    grid-area: stack;
  }

  .announcement-bar__slide {
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
    content-visibility: visible;
    place-content: center;
  }

  .announcement-bar__slide[aria-hidden='true'] {
    opacity: 0;
    visibility: hidden;
  }

  .announcement-bar__slider slideshow-arrows {
    padding: 0;
    mix-blend-mode: normal;
  }

  .announcement-bar__slider slideshow-arrows .slideshow-control {
    color: var(--color-foreground);
  }

  .announcement-bar__slider .slideshow-control {
    display: flex;
    padding: 0;
    width: var(--button-size);
    height: var(--button-size);
    align-items: center;
    justify-content: center;
    opacity: 1;
    animation: none;
  }

  @media screen and (min-width: 750px) {
    .announcement-bar__slider .slideshow-control {
      --slideshow-control-offset: calc((var(--button-size) - var(--icon-size-xs)) / 2);
    }

    .section--page-width .announcement-bar__slider .slideshow-control.slideshow-control--previous {
      transform: translateX(var(--slideshow-control-offset));
    }
  }

  .announcement-bar__slider .slideshow-control .svg-wrapper {
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
  }

  .announcement-bar__text:first-child {
    margin: 0;
  }

  .announcement-bar__link {
    position: absolute;
    inset: 0;
  }

  @media screen and (max-width: 989px) {
    .announcement-bar__layout {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .announcement-bar__side--left,
    .announcement-bar__side--right {
      justify-content: center;
    }

    .announcement-bar__slider {
      order: 2;
    }

    .announcement-bar__side--left {
      order: 1;
    }

    .announcement-bar__side--right {
      order: 3;
    }
  }

  @media screen and (max-width: 749px) {
    .announcement-bar__slider {
      grid-column: 1 / -1;
    }

    .announcement-bar__slides {
      width: calc(100% - var(--button-size) * 2);
      max-width: 100%;
    }

    .announcement-bar__side-link,
    .announcement-bar__side-text {
      font-size: 1.3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "t:settings.scroll_speed",
      "min": 2,
      "max": 10,
      "default": 5,
      "unit": "sec"
    },
    {
  "type": "header",
  "content": "Contenido lateral"
},
{
  "type": "text",
  "id": "left_text",
  "label": "Texto izquierda",
  "default": "España"
},
{
  "type": "url",
  "id": "left_link",
  "label": "Enlace izquierda"
},
{
  "type": "checkbox",
  "id": "show_location_icon",
  "label": "Mostrar icono ubicación",
  "default": true
},
{
  "type": "text",
  "id": "right_link_1_text",
  "label": "Texto derecha 1",
  "default": "Profesional"
},
{
  "type": "url",
  "id": "right_link_1_url",
  "label": "Enlace derecha 1"
},
{
  "type": "checkbox",
  "id": "show_right_separator",
  "label": "Mostrar separador",
  "default": true
},
{
  "type": "image_picker",
  "id": "right_flag",
  "label": "Bandera derecha"
},
{
  "type": "text",
  "id": "right_link_2_text",
  "label": "Texto derecha 2",
  "default": "Español"
},
{
  "type": "url",
  "id": "right_link_2_url",
  "label": "Enlace derecha 2"
},
{
  "type": "checkbox",
  "id": "show_language_arrow",
  "label": "Mostrar flecha idioma",
  "default": true
},
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-4",
      "label": "t:settings.color_scheme"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
