{% liquid
  assign current_product = product
  assign first_variant = current_product.selected_or_first_available_variant

  assign breve_descripcion = current_product.metafields.custom.custom_breve_descripcion
  assign detalles_producto = current_product.metafields.custom.custom_detalles_producto
  assign instrucciones = current_product.metafields.custom.custom_instrucciones

assign video_1_url = current_product.metafields.custom.custom_video_1_url.value | append: ''
assign video_2_url = current_product.metafields.custom.custom_video_2_url.value | append: ''
assign video_3_url = current_product.metafields.custom.custom_video_3_url.value | append: ''

  assign video_1_title = current_product.metafields.custom.custom_video_1_title.value
  assign video_2_title = current_product.metafields.custom.custom_video_2_title.value
  assign video_3_title = current_product.metafields.custom.custom_video_3_title.value

  assign current_sku = first_variant.sku
  assign breadcrumb_collection = current_product.collections.first
%}

<section class="main-product-custom main-product-custom--{{ section.id }}">
  <div class="main-product-custom__container">

    {% if section.settings.show_breadcrumbs %}
      <nav class="main-product-custom__breadcrumbs" aria-label="Migas de pan">
        <a href="{{ routes.root_url }}">{{ section.settings.home_breadcrumb_label }}</a>

        {% if breadcrumb_collection != blank %}
          <span>/</span>
          <a href="{{ breadcrumb_collection.url }}">{{ breadcrumb_collection.title }}</a>
        {% endif %}

        <span>/</span>
        <span>{{ current_product.title }}</span>
      </nav>
    {% endif %}

    <div class="main-product-custom__top">
      <div class="main-product-custom__gallery">
        {% if current_product.media.size > 0 %}
          <div class="main-product-custom__gallery-grid">
            <div class="main-product-custom__thumbs">
              {% for media in current_product.media %}
                <button
                  class="main-product-custom__thumb {% if forloop.first %}is-active{% endif %}"
                  type="button"
                  data-media-thumb
                  data-target-id="media-{{ media.id }}"
                  aria-label="Ver imagen {{ forloop.index }}"
                >
                  {% if media.preview_image != blank %}
                    <img
                      src="{{ media.preview_image | image_url: width: 180 }}"
                      alt="{{ media.alt | escape }}"
                      loading="lazy"
                      width="{{ media.preview_image.width }}"
                      height="{{ media.preview_image.height }}"
                    >
                  {% endif %}
                </button>
              {% endfor %}
            </div>

            <div class="main-product-custom__main-media">
              {% for media in current_product.media %}
                <div
                  class="main-product-custom__media-item {% if forloop.first %}is-active{% endif %}"
                  id="media-{{ media.id }}"
                  data-media-panel
                >
                  {% case media.media_type %}
                    {% when 'image' %}
                      <img
                        src="{{ media | image_url: width: 1600 }}"
                        alt="{{ media.alt | escape }}"
                        loading="lazy"
                        width="{{ media.width }}"
                        height="{{ media.height }}"
                      >
                    {% when 'external_video' %}
                      {{ media | external_video_tag: class: 'main-product-custom__video', loading: 'lazy' }}
                    {% when 'video' %}
                      {{ media | video_tag: class: 'main-product-custom__video', controls: true }}
                    {% else %}
                      {% if media.preview_image != blank %}
                        <img
                          src="{{ media.preview_image | image_url: width: 1600 }}"
                          alt="{{ media.alt | escape }}"
                          loading="lazy"
                          width="{{ media.preview_image.width }}"
                          height="{{ media.preview_image.height }}"
                        >
                      {% endif %}
                  {% endcase %}
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>

      <div class="main-product-custom__info">
        {% if section.settings.show_vendor and current_product.vendor != blank %}
          <div class="main-product-custom__vendor">{{ current_product.vendor }}</div>
        {% endif %}

        <h1 class="main-product-custom__title">{{ current_product.title }}</h1>

        {% if current_sku != blank %}
          <div class="main-product-custom__meta-line">
            <span class="main-product-custom__meta-label">Referencia</span>
            <span class="main-product-custom__meta-value">{{ current_sku }}</span>
          </div>
        {% endif %}

        <div class="main-product-custom__price-wrap">
          {% if first_variant.compare_at_price > first_variant.price %}
            <span class="main-product-custom__price main-product-custom__price--compare">
              {{ first_variant.compare_at_price | money }}
            </span>
          {% endif %}
          <span class="main-product-custom__price">
            {{ first_variant.price | money }}
          </span>
        </div>

        <div class="main-product-custom__taxes">
          {{ section.settings.tax_text }}
        </div>

        {% if section.settings.show_short_description and breve_descripcion != blank %}
          <div class="main-product-custom__short-description rte">
            {{ breve_descripcion | metafield_tag }}
          </div>
        {% endif %}

        {% form 'product', current_product, class: 'main-product-custom__form', data-type: 'add-to-cart-form' %}
          {% unless current_product.has_only_default_variant %}
            <div class="main-product-custom__variants">
              {% for option in current_product.options_with_values %}
                <div class="main-product-custom__option">
                  <label class="main-product-custom__option-label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                    {{ option.name }}
                  </label>
                  <select
                    id="Option-{{ section.id }}-{{ forloop.index0 }}"
                    class="main-product-custom__select"
                    name="options[{{ option.name | escape }}]"
                  >
                    {% for value in option.values %}
                      <option
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}selected="selected"{% endif %}
                      >
                        {{ value }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            </div>
          {% endunless %}

          <input type="hidden" name="id" value="{{ first_variant.id }}">

          <div class="main-product-custom__purchase-row">
            <div class="main-product-custom__quantity" data-quantity-wrapper>
              <button type="button" class="main-product-custom__qty-btn" data-qty-minus aria-label="Restar cantidad">−</button>
              <input
                class="main-product-custom__qty-input"
                type="number"
                name="quantity"
                min="1"
                value="1"
                inputmode="numeric"
                pattern="[0-9]*"
              >
              <button type="button" class="main-product-custom__qty-btn" data-qty-plus aria-label="Sumar cantidad">+</button>
            </div>

            <button
              type="submit"
              name="add"
              class="main-product-custom__add-to-cart"
              {% unless first_variant.available %}disabled{% endunless %}
            >
              {% if first_variant.available %}
                {{ section.settings.add_to_cart_text }}
              {% else %}
                Agotado
              {% endif %}
            </button>

            <button
              type="button"
              class="main-product-custom__wishlist"
              aria-label="Añadir a wishlist"
              aria-pressed="false"
              data-wishlist-toggle
            >
              <span class="main-product-custom__wishlist-icon" aria-hidden="true">♡</span>
            </button>
          </div>
        {% endform %}

        <div class="main-product-custom__accordions">
          {% if breve_descripcion != blank %}
            <details class="main-product-custom__accordion" open>
              <summary>Breve descripción</summary>
              <div class="main-product-custom__accordion-content rte">
                {{ breve_descripcion | metafield_tag }}
              </div>
            </details>
          {% endif %}

          {% if detalles_producto != blank %}
            <details class="main-product-custom__accordion">
              <summary>Detalles del producto</summary>
              <div class="main-product-custom__accordion-content rte">
                {{ detalles_producto | metafield_tag }}
              </div>
            </details>
          {% endif %}

          {% if instrucciones != blank %}
            <details class="main-product-custom__accordion">
              <summary>Instrucciones</summary>
              <div class="main-product-custom__accordion-content rte">
                {{ instrucciones | metafield_tag }}
              </div>
            </details>
          {% endif %}
        </div>
      </div>
    </div>

    {% if section.settings.show_related_products %}
      {% assign related_collection = collections[section.settings.related_collection] %}
      {% if related_collection != blank and related_collection.products_count > 0 %}
        <div class="main-product-custom__related">
          <h2 class="main-product-custom__section-title">{{ section.settings.related_title }}</h2>
          <div class="main-product-custom__related-grid">
            {% for related_product in related_collection.products limit: 4 %}
              <a href="{{ related_product.url }}" class="main-product-custom__card">
                {% if related_product.featured_image != blank %}
                  <div class="main-product-custom__card-image">
                    <img
                      src="{{ related_product.featured_image | image_url: width: 600 }}"
                      alt="{{ related_product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="{{ related_product.featured_image.width }}"
                      height="{{ related_product.featured_image.height }}"
                    >
                  </div>
                {% endif %}
                <div class="main-product-custom__card-title">{{ related_product.title }}</div>
                <div class="main-product-custom__card-price">{{ related_product.price | money }}</div>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endif %}
{% assign has_videos = false %}
{% if video_1_url != blank or video_2_url != blank or video_3_url != blank %}
  {% assign has_videos = true %}
{% endif %}

{% if section.settings.show_videos and has_videos %}
  <div class="main-product-custom__videos">
    <h2 class="main-product-custom__section-title">{{ section.settings.videos_title }}</h2>

    <div class="main-product-custom__videos-grid">
      {% if video_1_url != blank %}
        {% assign video_1_id = video_1_url | remove: 'https://www.youtube.com/watch?v=' | remove: 'http://www.youtube.com/watch?v=' | remove: 'https://youtube.com/watch?v=' | remove: 'http://youtube.com/watch?v=' | remove: 'https://youtu.be/' | remove: 'http://youtu.be/' | split: '&' | first | split: '?' | first %}
        <div class="main-product-custom__video-card">
          <h3>{{ video_1_title | default: 'Presentación' }}</h3>
          <div class="main-product-custom__video-embed">
            <iframe
              src="https://www.youtube-nocookie.com/embed/{{ video_1_id }}?rel=0"
              title="{{ video_1_title | default: 'Presentación' | escape }}"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      {% endif %}

      {% if video_2_url != blank %}
        {% assign video_2_id = video_2_url | remove: 'https://www.youtube.com/watch?v=' | remove: 'http://www.youtube.com/watch?v=' | remove: 'https://youtube.com/watch?v=' | remove: 'http://youtube.com/watch?v=' | remove: 'https://youtu.be/' | remove: 'http://youtu.be/' | split: '&' | first | split: '?' | first %}
        <div class="main-product-custom__video-card">
          <h3>{{ video_2_title | default: 'Contenido del kit' }}</h3>
          <div class="main-product-custom__video-embed">
            <iframe
              src="https://www.youtube-nocookie.com/embed/{{ video_2_id }}?rel=0"
              title="{{ video_2_title | default: 'Contenido del kit' | escape }}"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      {% endif %}

      {% if video_3_url != blank %}
        {% assign video_3_id = video_3_url | remove: 'https://www.youtube.com/watch?v=' | remove: 'http://www.youtube.com/watch?v=' | remove: 'https://youtube.com/watch?v=' | remove: 'http://youtube.com/watch?v=' | remove: 'https://youtu.be/' | remove: 'http://youtu.be/' | split: '&' | first | split: '?' | first %}
        <div class="main-product-custom__video-card">
          <h3>{{ video_3_title | default: 'Instrucciones' }}</h3>
          <div class="main-product-custom__video-embed">
            <iframe
              src="https://www.youtube-nocookie.com/embed/{{ video_3_id }}?rel=0"
              title="{{ video_3_title | default: 'Instrucciones' | escape }}"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}
</div>
</section>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sectionRoot = document.querySelector('.main-product-custom--{{ section.id }}');
    if (!sectionRoot) return;

    const thumbs = sectionRoot.querySelectorAll('[data-media-thumb]');
    const panels = sectionRoot.querySelectorAll('[data-media-panel]');

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const targetId = thumb.getAttribute('data-target-id');

        thumbs.forEach((item) => item.classList.remove('is-active'));
        panels.forEach((panel) => panel.classList.remove('is-active'));

        thumb.classList.add('is-active');

        const targetPanel = sectionRoot.querySelector('#' + CSS.escape(targetId));
        if (targetPanel) targetPanel.classList.add('is-active');
      });
    });

    const qtyWrapper = sectionRoot.querySelector('[data-quantity-wrapper]');
    if (qtyWrapper) {
      const input = qtyWrapper.querySelector('.main-product-custom__qty-input');
      const minus = qtyWrapper.querySelector('[data-qty-minus]');
      const plus = qtyWrapper.querySelector('[data-qty-plus]');

      minus?.addEventListener('click', () => {
        const current = parseInt(input.value || '1', 10);
        input.value = Math.max(1, current - 1);
        input.dispatchEvent(new Event('change', { bubbles: true }));
      });

      plus?.addEventListener('click', () => {
        const current = parseInt(input.value || '1', 10);
        input.value = current + 1;
        input.dispatchEvent(new Event('change', { bubbles: true }));
      });
    }

    const wishlistBtn = sectionRoot.querySelector('[data-wishlist-toggle]');
    if (wishlistBtn) {
      wishlistBtn.addEventListener('click', () => {
        const isPressed = wishlistBtn.getAttribute('aria-pressed') === 'true';
        wishlistBtn.setAttribute('aria-pressed', String(!isPressed));
        const icon = wishlistBtn.querySelector('.main-product-custom__wishlist-icon');
        if (icon) icon.textContent = !isPressed ? '♥' : '♡';
        wishlistBtn.classList.toggle('is-active', !isPressed);
      });
    }
  });
</script>

<style>
  .main-product-custom--{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  .main-product-custom--{{ section.id }} .main-product-custom__container {
    max-width: 1360px;
    margin: 0 auto;
    padding: px 28px 56px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__video-embed iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 260px;
    border: 0;
    border-radius: 10px;
    overflow: hidden;
  }
  @media screen and (max-width: 749px) {
    .main-product-custom--{{ section.id }} .main-product-custom__video-embed iframe {
      min-height: 220px;
    }
  }
  .main-product-custom--{{ section.id }} .main-product-custom__breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 26px;
    font-size: 13px;
    line-height: 1.4;
    color: rgba(0, 0, 0, 0.65);
  }

  .main-product-custom--{{ section.id }} .main-product-custom__breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__top {
    display: grid;
    grid-template-columns: minmax(0, 58%) minmax(360px, 42%);
    gap: 32px;
    align-items: start;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__gallery-grid {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 16px;
    align-items: start;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__thumbs {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__thumb {
    border: 1px solid rgba(0,0,0,0.08);
    background: #fff;
    padding: 0;
    cursor: pointer;
    border-radius: 6px;
    overflow: hidden;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__thumb.is-active {
    border-color: {{ section.settings.accent_color }};
  }

  .main-product-custom--{{ section.id }} .main-product-custom__thumb img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__main-media {
    min-height: 0;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__media-item {
    display: none;
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__media-item.is-active {
    display: block;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__media-item img,
  .main-product-custom--{{ section.id }} .main-product-custom__media-item iframe,
  .main-product-custom--{{ section.id }} .main-product-custom__media-item video {
    width: 100%;
    height: auto;
    display: block;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__info {
    position: sticky;
    top: 24px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__vendor {
    margin: 0 0 8px;
    font-size: 13px;
    opacity: .7;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__title {
    margin: 0 0 14px;
    font-size: 32px;
    line-height: 1.05;
    font-weight: 800;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__meta-line {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 10px;
    font-size: 14px;
    line-height: 1.4;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__meta-label {
    opacity: .65;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__meta-value {
    font-weight: 600;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__price-wrap {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 6px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__price {
    font-size: 30px;
    font-weight: 700;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__price--compare {
    text-decoration: line-through;
    opacity: .5;
    font-size: 18px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__taxes {
    margin-bottom: 18px;
    font-size: 13px;
    opacity: .75;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__short-description {
    margin-bottom: 18px;
    font-size: 15px;
    line-height: 1.6;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__variants {
    display: grid;
    gap: 14px;
    margin-bottom: 16px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__option {
    display: grid;
    gap: 6px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__option-label {
    font-size: 13px;
    font-weight: 600;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__select {
    width: 100%;
    min-height: 44px;
    border: 1px solid rgba(0,0,0,0.14);
    border-radius: 8px;
    padding: 0 14px;
    background: #fff;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__purchase-row {
    display: grid;
    grid-template-columns: 132px minmax(0, 1fr) 56px;
    gap: 12px;
    align-items: center;
    margin-bottom: 18px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__quantity {
    display: grid;
    grid-template-columns: 40px 1fr 40px;
    align-items: center;
    min-height: 50px;
    border: 1px solid rgba(0,0,0,0.14);
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__qty-btn {
    border: 0;
    background: transparent;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    height: 100%;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__qty-input {
    width: 100%;
    border: 0;
    background: transparent;
    text-align: center;
