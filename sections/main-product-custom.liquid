{% liquid
  assign current_product = product
  assign first_variant = current_product.selected_or_first_available_variant

  assign breve_descripcion_obj = current_product.metafields.custom.breve_descripcion
  assign detalles_producto_obj = current_product.metafields.custom.detalles_producto
  assign instrucciones_obj = current_product.metafields.custom.instrucciones

  assign video_1_url = current_product.metafields.custom.video_1_url.value
  assign video_2_url = current_product.metafields.custom.video_2_url.value
  assign video_3_url = current_product.metafields.custom.video_3_url.value

  assign video_1_title = current_product.metafields.custom.video_1_title.value
  assign video_2_title = current_product.metafields.custom.video_2_title.value
  assign video_3_title = current_product.metafields.custom.video_3_title.value
%}

<section class="main-product-custom main-product-custom--{{ section.id }}">
  <div class="main-product-custom__container">

    <!-- INFO -->
    <div class="main-product-custom__info">
      <h1>{{ current_product.title }}</h1>

      <div>
        {{ first_variant.price | money }}
      </div>

      <!-- 🔥 METACAMPOS -->
      {% if breve_descripcion_obj != blank %}
        <div class="rte">
          {{ breve_descripcion_obj | metafield_tag }}
        </div>
      {% endif %}

      {% if detalles_producto_obj != blank %}
        <div class="rte">
          {{ detalles_producto_obj | metafield_tag }}
        </div>
      {% endif %}

      {% if instrucciones_obj != blank %}
        <div class="rte">
          {{ instrucciones_obj | metafield_tag }}
        </div>
      {% endif %}
    </div>

    <!-- 🎥 VIDEOS -->
    {% if video_1_url or video_2_url or video_3_url %}
      <div class="videos">

        {% if video_1_url != blank %}
          <div>
            <h3>{{ video_1_title | default: 'Video 1' }}</h3>
            {{ video_1_url | external_video_url | external_video_tag }}
          </div>
        {% endif %}

        {% if video_2_url != blank %}
          <div>
            <h3>{{ video_2_title | default: 'Video 2' }}</h3>
            {{ video_2_url | external_video_url | external_video_tag }}
          </div>
        {% endif %}

        {% if video_3_url != blank %}
          <div>
            <h3>{{ video_3_title | default: 'Video 3' }}</h3>
            {{ video_3_url | external_video_url | external_video_tag }}
          </div>
        {% endif %}

      </div>
    {% endif %}

  </div>
</section>

<style>
  .main-product-custom__container {
    padding: 150px 20px;
  }

  .videos {
    margin-top: 40px;
  }

  .videos iframe {
    width: 100%;
    height: 300px;
  }
</style>