{% liquid
  assign current_product = product
  assign first_variant = current_product.selected_or_first_available_variant

  assign breve_descripcion = current_product.metafields.custom.breve_descripcion.value
  assign detalles_producto = current_product.metafields.custom.detalles_producto.value
  assign instrucciones = current_product.metafields.custom.instrucciones.value

  assign video_1_url = current_product.metafields.custom.video_1_url.value
  assign video_2_url = current_product.metafields.custom.video_2_url.value
  assign video_3_url = current_product.metafields.custom.video_3_url.value

  assign video_1_title = current_product.metafields.custom.video_1_title.value
  assign video_2_title = current_product.metafields.custom.video_2_title.value
  assign video_3_title = current_product.metafields.custom.video_3_title.value
%}

<section class="main-product-custom main-product-custom--{{ section.id }}">
  <div class="main-product-custom__container">
    <div class="main-product-custom__debug">
<p><strong>Breve descripción obj:</strong> {{ product.metafields.custom.breve_descripcion }}</p>
<p><strong>Breve descripción value:</strong> {{ product.metafields.custom.breve_descripcion.value }}</p>

<p><strong>Detalles obj:</strong> {{ product.metafields.custom.detalles_producto }}</p>
<p><strong>Detalles value:</strong> {{ product.metafields.custom.detalles_producto.value }}</p>

<p><strong>Instrucciones obj:</strong> {{ product.metafields.custom.instrucciones }}</p>
<p><strong>Instrucciones value:</strong> {{ product.metafields.custom.instrucciones.value }}</p>

<p><strong>Video 1 obj:</strong> {{ product.metafields.custom.video_1_url }}</p>
<p><strong>Video 1 value:</strong> {{ product.metafields.custom.video_1_url.value }}</p>

<p><strong>Video 1 title obj:</strong> {{ product.metafields.custom.video_1_title }}</p>
<p><strong>Video 1 title value:</strong> {{ product.metafields.custom.video_1_title.value }}</p>
    </div>

    <div class="main-product-custom__top">
      <div class="main-product-custom__gallery">
        {% if current_product.media.size > 0 %}
          <div class="main-product-custom__gallery-grid">
            <div class="main-product-custom__thumbs">
              {% for media in current_product.media %}
                <button
                  class="main-product-custom__thumb {% if forloop.first %}is-active{% endif %}"
                  type="button"
                  data-media-thumb
                  data-target-id="media-{{ media.id }}"
                  aria-label="Ver imagen {{ forloop.index }}"
                >
                  {% if media.preview_image != blank %}
                    <img
                      src="{{ media.preview_image | image_url: width: 180 }}"
                      alt="{{ media.alt | escape }}"
                      loading="lazy"
                      width="{{ media.preview_image.width }}"
                      height="{{ media.preview_image.height }}"
                    >
                  {% endif %}
                </button>
              {% endfor %}
            </div>

            <div class="main-product-custom__main-media">
              {% for media in current_product.media %}
                <div
                  class="main-product-custom__media-item {% if forloop.first %}is-active{% endif %}"
                  id="media-{{ media.id }}"
                  data-media-panel
                >
                  {% case media.media_type %}
                    {% when 'image' %}
                      <img
                        src="{{ media | image_url: width: 1600 }}"
                        alt="{{ media.alt | escape }}"
                        loading="lazy"
                        width="{{ media.width }}"
                        height="{{ media.height }}"
                      >
                    {% when 'external_video' %}
                      {{ media | external_video_tag: class: 'main-product-custom__video', loading: 'lazy' }}
                    {% when 'video' %}
                      {{ media | video_tag: class: 'main-product-custom__video', controls: true }}
                    {% else %}
                      {% if media.preview_image != blank %}
                        <img
                          src="{{ media.preview_image | image_url: width: 1600 }}"
                          alt="{{ media.alt | escape }}"
                          loading="lazy"
                          width="{{ media.preview_image.width }}"
                          height="{{ media.preview_image.height }}"
                        >
                      {% endif %}
                  {% endcase %}
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>

      <div class="main-product-custom__info">
        {% if section.settings.show_vendor and current_product.vendor != blank %}
          <div class="main-product-custom__vendor">{{ current_product.vendor }}</div>
        {% endif %}

        <h1 class="main-product-custom__title">{{ current_product.title }}</h1>

        <div class="main-product-custom__price-wrap">
          {% if first_variant.compare_at_price > first_variant.price %}
            <span class="main-product-custom__price main-product-custom__price--compare">
              {{ first_variant.compare_at_price | money }}
            </span>
          {% endif %}
          <span class="main-product-custom__price">
            {{ first_variant.price | money }}
          </span>
        </div>

        {% if section.settings.show_short_description and breve_descripcion != blank %}
          <div class="main-product-custom__short-description">
            {{ breve_descripcion | newline_to_br }}
          </div>
        {% endif %}

        {% form 'product', current_product, class: 'main-product-custom__form', data-type: 'add-to-cart-form' %}
          {% unless current_product.has_only_default_variant %}
            <div class="main-product-custom__variants">
              {% for option in current_product.options_with_values %}
                <div class="main-product-custom__option">
                  <label class="main-product-custom__option-label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                    {{ option.name }}
                  </label>
                  <select
                    id="Option-{{ section.id }}-{{ forloop.index0 }}"
                    class="main-product-custom__select"
                    name="options[{{ option.name | escape }}]"
                  >
                    {% for value in option.values %}
                      <option
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}selected="selected"{% endif %}
                      >
                        {{ value }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            </div>
          {% endunless %}

          <input type="hidden" name="id" value="{{ first_variant.id }}">

          <div class="main-product-custom__buybox">
            <button
              type="submit"
              name="add"
              class="main-product-custom__add-to-cart"
              {% unless first_variant.available %}disabled{% endunless %}
            >
              {% if first_variant.available %}
                {{ section.settings.add_to_cart_text }}
              {% else %}
                Agotado
              {% endif %}
            </button>
          </div>
        {% endform %}

        <div class="main-product-custom__accordions">
          {% if breve_descripcion != blank %}
            <details class="main-product-custom__accordion" open>
              <summary>Breve descripción</summary>
              <div class="main-product-custom__accordion-content">
                {{ breve_descripcion | newline_to_br }}
              </div>
            </details>
          {% endif %}

          {% if detalles_producto != blank %}
            <details class="main-product-custom__accordion">
              <summary>Detalles del producto</summary>
              <div class="main-product-custom__accordion-content">
                {{ detalles_producto | newline_to_br }}
              </div>
            </details>
          {% endif %}

          {% if instrucciones != blank %}
            <details class="main-product-custom__accordion">
              <summary>Instrucciones</summary>
              <div class="main-product-custom__accordion-content">
                {{ instrucciones | newline_to_br }}
              </div>
            </details>
          {% endif %}
        </div>
      </div>
    </div>

    {% if section.settings.show_related_products %}
      {% assign related_collection = collections[section.settings.related_collection] %}
      {% if related_collection != blank and related_collection.products_count > 0 %}
        <div class="main-product-custom__related">
          <h2 class="main-product-custom__section-title">{{ section.settings.related_title }}</h2>
          <div class="main-product-custom__related-grid">
            {% for related_product in related_collection.products limit: 4 %}
              <a href="{{ related_product.url }}" class="main-product-custom__card">
                {% if related_product.featured_image != blank %}
                  <div class="main-product-custom__card-image">
                    <img
                      src="{{ related_product.featured_image | image_url: width: 600 }}"
                      alt="{{ related_product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="{{ related_product.featured_image.width }}"
                      height="{{ related_product.featured_image.height }}"
                    >
                  </div>
                {% endif %}
                <div class="main-product-custom__card-title">{{ related_product.title }}</div>
                <div class="main-product-custom__card-price">{{ related_product.price | money }}</div>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endif %}

    {% assign has_videos = false %}
    {% if video_1_url != blank or video_2_url != blank or video_3_url != blank %}
      {% assign has_videos = true %}
    {% endif %}

    {% if section.settings.show_videos and has_videos %}
      <div class="main-product-custom__videos">
        <h2 class="main-product-custom__section-title">{{ section.settings.videos_title }}</h2>

        <div class="main-product-custom__videos-grid">
          {% if video_1_url != blank %}
            <div class="main-product-custom__video-card">
              <h3>{{ video_1_title | default: 'Presentación' }}</h3>
              <div class="main-product-custom__video-embed">
                {{ video_1_url | external_video_url: autoplay: false | external_video_tag }}
              </div>
            </div>
          {% endif %}

          {% if video_2_url != blank %}
            <div class="main-product-custom__video-card">
              <h3>{{ video_2_title | default: 'Contenido del kit' }}</h3>
              <div class="main-product-custom__video-embed">
                {{ video_2_url | external_video_url: autoplay: false | external_video_tag }}
              </div>
            </div>
          {% endif %}

          {% if video_3_url != blank %}
            <div class="main-product-custom__video-card">
              <h3>{{ video_3_title | default: 'Instrucciones' }}</h3>
              <div class="main-product-custom__video-embed">
                {{ video_3_url | external_video_url: autoplay: false | external_video_tag }}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sectionRoot = document.querySelector('.main-product-custom--{{ section.id }}');
    if (!sectionRoot) return;

    const thumbs = sectionRoot.querySelectorAll('[data-media-thumb]');
    const panels = sectionRoot.querySelectorAll('[data-media-panel]');

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const targetId = thumb.getAttribute('data-target-id');

        thumbs.forEach((item) => item.classList.remove('is-active'));
        panels.forEach((panel) => panel.classList.remove('is-active'));

        thumb.classList.add('is-active');

        const targetPanel = sectionRoot.querySelector('#' + CSS.escape(targetId));
        if (targetPanel) targetPanel.classList.add('is-active');
      });
    });
  });
</script>

<style>
  .main-product-custom--{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  .main-product-custom--{{ section.id }} .main-product-custom__container {
    max-width: 1360px;
    margin: 0 auto;
    padding: 170px 28px 56px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__debug {
    display: block;
    background: #fff3a6;
    color: #111;
    padding: 16px;
    margin-bottom: 20px;
    border-radius: 8px;
    font-size: 14px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__top {
    display: grid;
    grid-template-columns: minmax(0, 58%) minmax(360px, 42%);
    gap: 32px;
    align-items: start;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__gallery-grid {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 16px;
    align-items: start;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__thumbs {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__thumb {
    border: 1px solid rgba(0,0,0,0.08);
    background: #fff;
    padding: 0;
    cursor: pointer;
    border-radius: 6px;
    overflow: hidden;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__thumb.is-active {
    border-color: {{ section.settings.accent_color }};
  }

  .main-product-custom--{{ section.id }} .main-product-custom__thumb img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__main-media {
    min-height: 0;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__media-item {
    display: none;
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__media-item.is-active {
    display: block;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__media-item img,
  .main-product-custom--{{ section.id }} .main-product-custom__media-item iframe,
  .main-product-custom--{{ section.id }} .main-product-custom__media-item video {
    width: 100%;
    height: auto;
    display: block;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__info {
    position: sticky;
    top: 24px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__vendor {
    margin: 0 0 8px;
    font-size: 13px;
    opacity: .7;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__title {
    margin: 0 0 14px;
    font-size: 32px;
    line-height: 1.05;
    font-weight: 800;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__price-wrap {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 18px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__price {
    font-size: 30px;
    font-weight: 700;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__price--compare {
    text-decoration: line-through;
    opacity: .5;
    font-size: 18px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__short-description {
    margin-bottom: 18px;
    font-size: 15px;
    line-height: 1.6;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__variants {
    display: grid;
    gap: 14px;
    margin-bottom: 16px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__option {
    display: grid;
    gap: 6px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__option-label {
    font-size: 13px;
    font-weight: 600;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__select {
    width: 100%;
    min-height: 44px;
    border: 1px solid rgba(0,0,0,0.14);
    border-radius: 8px;
    padding: 0 14px;
    background: #fff;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__buybox {
    margin-bottom: 18px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__add-to-cart {
    width: 100%;
    min-height: 50px;
    border-radius: 10px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
    font-weight: 700;
    border: 0;
    cursor: pointer;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__accordion {
    border-top: 1px solid rgba(0,0,0,0.1);
    padding: 14px 0;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__accordion:last-child {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }

  .main-product-custom--{{ section.id }} .main-product-custom__accordion summary {
    cursor: pointer;
    font-weight: 700;
    list-style: none;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__accordion summary::-webkit-details-marker {
    display: none;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__accordion-content {
    padding-top: 10px;
    font-size: 14px;
    line-height: 1.7;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__related,
  .main-product-custom--{{ section.id }} .main-product-custom__videos {
    margin-top: 48px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__section-title {
    font-size: 22px;
    font-weight: 800;
    margin-bottom: 20px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__related-grid,
  .main-product-custom--{{ section.id }} .main-product-custom__videos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__card {
    text-decoration: none;
    color: inherit;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__card-image {
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__card-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__card-title {
    font-size: 14px;
    line-height: 1.4;
    margin-bottom: 6px;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__card-price {
    font-size: 14px;
    font-weight: 700;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__video-card h3 {
    margin: 0 0 12px;
    font-size: 18px;
    font-weight: 700;
  }

  .main-product-custom--{{ section.id }} .main-product-custom__video-embed iframe,
  .main-product-custom--{{ section.id }} .main-product-custom__video-embed video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    border-radius: 10px;
    overflow: hidden;
  }

  @media screen and (max-width: 1200px) {
    .main-product-custom--{{ section.id }} .main-product-custom__top {
      grid-template-columns: 1fr;
    }

    .main-product-custom--{{ section.id }} .main-product-custom__info {
      position: static;
    }
  }

  @media screen and (max-width: 749px) {
    .main-product-custom--{{ section.id }} .main-product-custom__container {
      padding: 120px 16px 40px;
    }

    .main-product-custom--{{ section.id }} .main-product-custom__gallery-grid {
      grid-template-columns: 1fr;
    }

    .main-product-custom--{{ section.id }} .main-product-custom__thumbs {
      flex-direction: row;
      overflow-x: auto;
    }

    .main-product-custom--{{ section.id }} .main-product-custom__related-grid,
    .main-product-custom--{{ section.id }} .main-product-custom__videos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Main product custom",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Mostrar marca",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_short_description",
      "label": "Mostrar descripción corta",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_related_products",
      "label": "Mostrar productos recomendados",
      "default": true
    },
    {
      "type": "text",
      "id": "related_title",
      "label": "Título recomendados",
      "default": "También puedes necesitar..."
    },
    {
      "type": "collection",
      "id": "related_collection",
      "label": "Colección recomendados"
    },
    {
      "type": "checkbox",
      "id": "show_videos",
      "label": "Mostrar vídeos",
      "default": true
    },
    {
      "type": "text",
      "id": "videos_title",
      "label": "Título vídeos",
      "default": "Vídeos"
    },
    {
      "type": "text",
      "id": "add_to_cart_text",
      "label": "Texto botón añadir al carrito",
      "default": "Añadir al carrito"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color fondo",
      "default": "#f5f5f7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color texto",
      "default": "#1e1e1e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color acento",
      "default": "#27348b"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Color botón",
      "default": "#27348b"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Color texto botón",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Main product custom"
    }
  ]
}
{% endschema %}